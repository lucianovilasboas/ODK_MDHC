sta/condicao_geral_saude/avaliacao_saude_mental" type="string" required="true()"/><bind nodeset="/data/meta/entity/@create" calculate="true()" readonly="true()" type="string"/><bind nodeset="/data/meta/entity/@id" readonly="true()" type="string"/><setvalue ref="/data/meta/entity/@id" event="odk-instance-first-load" value="uuid()"/><bind nodeset="/data/meta/entity/label" calculate="concat(normalize-space( /data/preliminar/nome_pessoa_idosa ), '|', normalize-space( /data/preliminar/bairro ), '-',  /data/preliminar/municipio_nome , '/',  /data/preliminar/uf , '|',  /data/preliminar/auto_id )" readonly="true()" type="string"/><bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/></model></h:head><h:body><group ref="/data/preliminar"><label>PRELIMINAR</label><input ref="/data/preliminar/inicio_instruction" appearance="autocomplete"><label>Leia pausadamente cada questão para o entrevistado, mas não influencie a resposta.</label></input><input ref="/data/preliminar/nome_agente"><label>Nome do agente</label></input><input ref="/data/preliminar/bairro"><label>Bairro ou comunidade</label></input><input ref="/data/preliminar/nome_pessoa_idosa"><label>Nome da pessoa idosa</label></input><select1 ref="/data/preliminar/uf" appearance="autocomplete"><label>Estado</label><itemset nodeset="instance('uf')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/preliminar/municipio" appearance="autocomplete"><label>Municipio</label><itemset nodeset="instance('mun')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><input ref="/data/preliminar/municipio_outro"><label>Qual município?</label></input><input ref="/data/preliminar/endereco"><label>Endereço</label></input><input ref="/data/preliminar/localizacao"><label>Localização</label></input><select1 ref="/data/preliminar/respondente"><label>Respondente</label><itemset nodeset="instance('respondente')/root/item"><value ref="name"/><label ref="label"/