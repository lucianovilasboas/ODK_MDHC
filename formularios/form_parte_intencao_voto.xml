      <bind nodeset="/data/start" jr:preload="timestamp" type="dateTime" jr:preloadParams="start"/>
      <bind nodeset="/data/end" jr:preload="timestamp" type="dateTime" jr:preloadParams="end"/>
      <bind nodeset="/data/deviceid" jr:preload="property" type="string" jr:preloadParams="deviceid"/>
      <bind nodeset="/data/entrevistador" type="string" required="true()"/>
      <bind nodeset="/data/data" type="date" required="true()"/>
      <bind nodeset="/data/municipio" type="string" required="true()"/>
      <bind nodeset="/data/uf" type="string" required="true()"/>
      <bind nodeset="/data/sexo" type="string" required="true()"/>
      <bind nodeset="/data/idade" type="int" required="true()" constraint=". &gt;= 16 and . &lt;= 120" jr:constraintMsg="Idade deve estar entre 16 e 120 anos"/>
      <bind nodeset="/data/escolaridade" type="string" required="true()"/>
      <bind nodeset="/data/renda_familiar" type="string" required="true()"/>
      <bind nodeset="/data/voto_espontaneo" type="string" required="true()"/>
      <bind nodeset="/data/outro_espontaneo" type="string" required="true()" relevant=" /data/voto_espontaneo  = 'outro'"/>
      <bind nodeset="/data/voto_estimulado" type="string" required="true()"/>
      <bind nodeset="/data/rejeicao" type="string" required="true()"/>
      <bind nodeset="/data/avaliacao_governo" type="string" required="true()"/>
      <bind nodeset="/data/observacoes" type="string"/>
      <bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/>
      <bind nodeset="/data/meta/instanceName" type="string" calculate="concat('IntencaoVoto - ',  /data/entrevistador , ' - ', format-date-time( /data/start , '%d/%m/%Y'))"/>
    </model>
  </h:head>
  <h:body>
    <input ref="/data/entrevistador">
      <label>Nome do entrevistador</label>
    </input>
    <input ref="/data/data">
      <label>Data da entrevista</label>
    </input>
    <input ref="/data/municipio">
      <label>Município</label>
      <hint>Digite o nome do município</hint>
    </input>
    <select1 ref="/data/uf">
      <label>Unidade Federativa</label>
      <itemset nodeset="instance('uf')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/data/sexo">
      <label>Sexo</label>
      <itemset nodeset="instance('sexo')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input ref="/data/idade">
      <label>Idade</label>
    </input>
    <select1 ref="/data/escolaridade">
      <label>Escolaridade</label>
      <itemset nodeset="instance('escolaridade')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/data/renda_familiar">
      <label>Renda familiar mensal</label>
      <itemset nodeset="instance('renda_familiar')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/data/voto_espontaneo">
      <label>Se a eleição para presidente fosse hoje, em quem você votaria?</label>
      <hint>Não leia os nomes. Aguarde a resposta espontânea do entrevistado.</hint>
      <itemset nodeset="instance('voto_espontaneo')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input ref="/data/outro_espontaneo">
      <label>Qual?</label>
    </input>
    <select1 ref="/data/voto_estimulado">
      <label>Se a eleição para presidente fosse hoje, em qual destes candidatos você votaria?</label>
      <hint>Leia os nomes: Lula, Flávio Bolsonaro, Zema, Caiado ou Outro.</hint>
      <itemset nodeset="instance('voto_estimulado')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/data/rejeicao">
      <label>Em quem você NÃO votaria de jeito nenhum?</label>
      <hint>Leia os nomes novamente, se necessário.</hint>
      <itemset nodeset="instance('rejeicao')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/data/avaliacao_governo">
      <label>Como você avalia o governo atual?</label>
      <itemset nodeset="instance('avaliacao_governo')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input ref="/data/observacoes">
      <label>Observações</label>
      <hint>Registre qualquer observação relevante sobre a entrevista.</hint>
    </input>
  </h:body>
</h:html>
