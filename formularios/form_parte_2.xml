<?xml version="1.0"?><h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:odk="http://www.opendatakit.org/xforms"><h:head><h:title>Formulário - Parte 2</h:title><model odk:xforms-version="1.0.0"><instance><data id="form_parte_2" version="1"><preliminar><pessoa_idosa/><localizacao/><respondente/><nota_recusa/></preliminar><entrevista><quem_outro/><acamado_domiciliado/><direitos_emergentes2_note/><direitos_emergentes_note/><impedido_opinar/><impedido_decidir/><dificuldade_cuidados/><dificuldade_cuidados_tipos/><injustica_legal/><vida_ameacada/><preso_ilegal/><dificuldade_saude/><direitos_vigentes_note/><discriminacao/><dificuldade_educacao/><educacao_tipos/><impedido_participacao_atividades/><impedido_reuniao_manifestacao/><reuniao_tipos/><qual_outro_politico/><dificuldade_beneficios/><invasao_privacidade/><moradia_inadequada/><falta_servicos_publicos/><impedido_utilizar_bem/><dificuldade_votacao/><dificuldade_acesso_justica/><direitos_vigentes_outras_note/><tratado_por_idade/><sofreu_violencia/><violencia/><profissionais_nao_explicaram/><direitos_estendidos/><barreiras_acessibilidade/><risco_desastre_violencia/></entrevista><meta><instanceID/></meta></data></instance><instance id="pessoas_idosas" src="jr://file-csv/pessoas_idosas.csv"/><instance id="respondente"><root><item><name>recusou_responder</name><label>Recusou responder</label></item><item><name>propria_pessoa</name><label>A própria pessoa idosa</label></item><item><name>outra_pessoa</name><label>Outra pessoa.</label></item></root></instance><instance id="sim_nao"><root><item><name>sim</name><label>Sim</label></item><item><name>nao</name><label>Não</label></item><item><name>ns_nr</name><label>Não sabe/não responde</label></item></root></instance><instance id="genero"><root><item><name>masculino</name><label>Masculino</label></item><item><name>feminino</name><label>Feminino</label></item></root></instance><instance id="violencia"><root><item><name>fisica</name><label>Violência física</label></item><item><name>sexual</name><label>Violência sexual</label></item><item><name>psicologica</name><label>Violência psicológica</label></item><item><name>patrimonial_financeira</name><label>Violência patrimonial, abuso financeiro ou material</label></item><item><name>discriminacao</name><label>Discriminação</label></item><item><name>negligencia</name><label>Negligência</label></item><item><name>abandono</name><label>Abandono</label></item><item><name>institucional</name><label>Violência institucional</label></item></root></instance><instance id="sim_nao_"><root><item><name>sim</name><label>Sim</label></item><item><name>nao</name><label>Não</label></item></root></instance><instance id="educacao_tipos"><root><item><name>permanencia</name><label>Permanência</label></item><item><name>acesso</name><label>Acesso</label></item><item><name>locomocao</name><label>Locomoção</label></item></root></instance><instance id="reuniao_tipos"><root><item><name>politico</name><label>Político</label></item><item><name>sindical</name><label>Sindical</label></item><item><name>civico</name><label>Cívico</label></item><item><name>social</name><label>Social</label></item><item><name>esportivo</name><label>Esportivo</label></item><item><name>outros</name><label>Outro</label></item></root></instance><instance id="dificuldade_cuidados_tipos"><root><item><name>saude</name><label>Saúde</label></item><item><name>assistencia_social</name><label>Assistência social</label></item><item><name>seguranca</name><label>Segurança</label></item><item><name>alimentacao</name><label>Alimentação</label></item><item><name>agua</name><label>Água</label></item><item><name>vestuario</name><label>Vestuário</label></item><item><name>habitacao</name><label>Habitação</label></item></root></instance><bind nodeset="/data/preliminar/pessoa_idosa" type="string" calculate="autocomplete" required="true()"/><bind nodeset="/data/preliminar/localizacao" type="geopoint" required="false()"/><bind nodeset="/data/preliminar/respondente" type="string" required="true()"/><bind nodeset="/data/preliminar/nota_recusa" readonly="true()" type="string" relevant=" /data/preliminar/respondente ='recusou_responder'"/><bind nodeset="/data/entrevista" relevant=" /data/preliminar/respondente !='recusou_responder'"/><bind nodeset="/data/entrevista/quem_outro" type="string" relevant="selected( /data/preliminar/respondente , 'outra_pessoa')" required="false()"/><bind nodeset="/data/entrevista/acamado_domiciliado" type="string" required="true()"/><bind nodeset="/data/entrevista/direitos_emergentes2_note" readonly="true()" type="string" required="false()"/><bind nodeset="/data/entrevista/direitos_emergentes_note" readonly="true()" type="string" required="false()"/><bind nodeset="/data/entrevista/impedido_opinar" type="string" required="true()"/><bind nodeset="/data/entrevista/impedido_decidir" type="string" required="true()"/><bind nodeset="/data/entrevista/dificuldade_cuidados" type="string" required="true()"/><bind nodeset="/data/entrevista/dificuldade_cuidados_tipos" type="string" relevant=" /data/entrevista/dificuldade_cuidados  = 'sim'" required="true()"/><bind nodeset="/data/entrevista/injustica_legal" type="string" required="true()"/><bind nodeset="/data/entrevista/vida_ameacada" type="string" required="true()"/><bind nodeset="/data/entrevista/preso_ilegal" type="string" required="true()"/><bind nodeset="/data/entrevista/dificuldade_saude" type="string" required="true()"/><bind nodeset="/data/entrevista/direitos_vigentes_note" readonly="true()" type="string" required="false()"/><bind nodeset="/data/entrevista/discriminacao" type="string" required="true()"/><bind nodeset="/data/entrevista/dificuldade_educacao" type="string" required="true()"/><bind nodeset="/data/entrevista/educacao_tipos" type="string" relevant=" /data/entrevista/dificuldade_educacao  = 'sim'" required="false()"/><bind nodeset="/data/entrevista/impedido_participacao_atividades" type="string" required="true()"/><bind nodeset="/data/entrevista/impedido_reuniao_manifestacao" type="string" required="true()"/><bind nodeset="/data/entrevista/reuniao_tipos" type="string" relevant=" /data/entrevista/impedido_reuniao_manifestacao  = 'sim'" required="true()"/><bind nodeset="/data/entrevista/qual_outro_politico" type="string" relevant="selected( /data/entrevista/reuniao_tipos , 'outros')" required="false()"/><bind nodeset="/data/entrevista/dificuldade_beneficios" type="string" required="true()"/><bind nodeset="/data/entrevista/invasao_privacidade" type="string" required="true()"/><bind nodeset="/data/entrevista/moradia_inadequada" type="string" required="true()"/><bind nodeset="/data/entrevista/falta_servicos_publicos" type="string" required="true()"/><bind nodeset="/data/entrevista/impedido_utilizar_bem" type="string" required="true()"/><bind nodeset="/data/entrevista/dificuldade_votacao" type="string" required="true()"/><bind nodeset="/data/entrevista/dificuldade_acesso_justica" type="string" required="true()"/><bind nodeset="/data/entrevista/direitos_vigentes_outras_note" readonly="true()" type="string" required="false()"/><bind nodeset="/data/entrevista/tratado_por_idade" type="string" required="true()"/><bind nodeset="/data/entrevista/sofreu_violencia" type="string" required="true()"/><bind nodeset="/data/entrevista/violencia" type="string" relevant=" /data/entrevista/sofreu_violencia  = 'sim'" required="true()"/><bind nodeset="/data/entrevista/profissionais_nao_explicaram" type="string" required="true()"/><bind nodeset="/data/entrevista/direitos_estendidos" readonly="true()" type="string" required="false()"/><bind nodeset="/data/entrevista/barreiras_acessibilidade" type="string" required="true()"/><bind nodeset="/data/entrevista/risco_desastre_violencia" type="string" required="true()"/><bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/></model></h:head><h:body><group ref="/data/preliminar"><label>PRELIMINAR</label><select1 ref="/data/preliminar/pessoa_idosa" appearance="autocomplete"><label>Pessoa idosa</label><itemset nodeset="instance('pessoas_idosas')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><input ref="/data/preliminar/localizacao"><label>Localização</label></input><select1 ref="/data/preliminar/respondente"><label>Respondente</label><itemset nodeset="instance('respondente')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><input ref="/data/preliminar/nota_recusa"><label>O(a) respondente recusou participar. Agradeça, finalize e envie o formulário.</label></input></group><group ref="/data/entrevista"><label>ENTREVISTA</label><input ref="/data/entrevista/quem_outro"><label>Quem está respondendo, caso seja outra pessoa?</label></input><select1 ref="/data/entrevista/acamado_domiciliado"><label>A pessoa idosa está acamada ou domiciliada no momento?</label><itemset nodeset="instance('sim_nao_')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><input ref="/data/entrevista/direitos_emergentes2_note"><label>"Faremos perguntas sobre situações que o (a) Sr (a) pode ter vivido após se tornar uma pessoa idosa."</label></input><input ref="/data/entrevista/direitos_emergentes_note"><label>6. DIREITOS EMERGENTES</label></input><select1 ref="/data/entrevista/impedido_opinar"><label>Após ter completado 60 anos, já foi impedido de emitir sua opinião sobre algum assunto ou deixaram de lhe repassar informação do seu interesse?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/impedido_decidir"><label>Após ter completado 60 anos, já foi impedido de tomar as decisões sobre sua vida?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/dificuldade_cuidados"><label>Após ter completado 60 anos, tem dificuldades de acessar o sistema integral de cuidados (saúde, assistência social, segurança, alimentação, água, vestuário e habitação)?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select ref="/data/entrevista/dificuldade_cuidados_tipos"><label>Se respondeu "Sim" na pergunta anterior, qual dificuldade?</label><itemset nodeset="instance('dificuldade_cuidados_tipos')/root/item"><value ref="name"/><label ref="label"/></itemset></select><select1 ref="/data/entrevista/injustica_legal"><label>Após ter completado 60 anos, já viveu alguma situação de injustiça perante a lei por ser uma pessoa idosa?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/vida_ameacada"><label>Após ter completado 60 anos, já teve a sua vida ameaçada ou a sua dignidade abalada por ação de uma pessoa ou uma instituição?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/preso_ilegal"><label>Após ter completado 60 anos, já foi mantido preso ou foi submetido a prisão de maneira ilegal?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/dificuldade_saude"><label>Após ter completado 60 anos, já teve dificuldade de acesso a cuidados de saúde física e mental, seja na rede pública ou privada?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><input ref="/data/entrevista/direitos_vigentes_note"><label>7. DIREITOS VIGENTES</label></input><select1 ref="/data/entrevista/discriminacao"><label>Após ter completado 60 anos, já sentiu menosprezado por causa de sua origem, jeito de vestir, crenças religiosas e outras discriminações?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/dificuldade_educacao"><label>Após ter completado 60 anos, já teve dificuldade para ter acesso à educação (permanência, acesso, locomoção)?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select ref="/data/entrevista/educacao_tipos"><label>Se respondeu "Sim", qual dificuldade?</label><itemset nodeset="instance('educacao_tipos')/root/item"><value ref="name"/><label ref="label"/></itemset></select><select1 ref="/data/entrevista/impedido_participacao_atividades"><label>Após ter completado 60 anos, já foi impedido ou não foram oferecidas condições para sua participação em atividades recreativas de lazer e esportivas?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/impedido_reuniao_manifestacao"><label>Após ter completado 60 anos, já teve dificuldade ou já foi impedido de realizar uma reunião pacífica, de participar de manifestação ou de formar algum grupo (político, sindical, cívico, social, esportivo, etc)?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select ref="/data/entrevista/reuniao_tipos"><label>Se "Sim", qual foi a dificuldade?</label><itemset nodeset="instance('reuniao_tipos')/root/item"><value ref="name"/><label ref="label"/></itemset></select><input ref="/data/entrevista/qual_outro_politico"><label>Se marcou "Outro", especifique:</label></input><select1 ref="/data/entrevista/dificuldade_beneficios"><label>Após ter completado 60 anos, já teve dificuldade de conseguir os benefícios sociais, como aposentadoria pelo INSS, o Benefício de Prestação Continuada (BPC/LOAS), ou algum outro benefício oferecido pelo governo?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/invasao_privacidade"><label>Após ter completado 60 anos, já sentiu que sua privacidade foi invadida ou sua intimidade foi exposta sem o seu consentimento?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/moradia_inadequada"><label>Após ter completado 60 anos, já viveu ou vive em uma moradia que não considerava adequada, segura, acessível e adaptável às suas necessidades?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/falta_servicos_publicos"><label>Após ter completado 60 anos, vive ou viveu em um meio ambiente que não contava com serviços públicos básicos?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/impedido_utilizar_bem"><label>Após ter completado 60 anos, já foi impedido de utilizar algum bem ou valor por ser uma pessoa idosa?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/dificuldade_votacao"><label>Após ter completado 60 anos, já teve dificuldade ou já foi impedido de votar, de se candidatar a um cargo político, ou de exercer algum cargo público por ser uma pessoa idosa?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/dificuldade_acesso_justica"><label>Após ter completado 60 anos, já teve dificuldade de ter acesso à justiça?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><input ref="/data/entrevista/direitos_vigentes_outras_note"><label>8. DIREITOS VIGENTES QUE NECESSITAM DE NOVAS INTERPRETAÇÕES</label></input><select1 ref="/data/entrevista/tratado_por_idade"><label>Já foi tratado(a) mal ou pior do que as outras pessoas por motivo da sua idade?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/sofreu_violencia"><label>Já sofreu algum tipo de violência?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select ref="/data/entrevista/violencia"><label>Qual tipo de violência?</label><itemset nodeset="instance('violencia')/root/item"><value ref="name"/><label ref="label"/></itemset></select><select1 ref="/data/entrevista/profissionais_nao_explicaram"><label>Quando faz tratamento de saúde, os profissionais já deixaram de explicar os riscos e benefícios e lhe impedem de escolher?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><input ref="/data/entrevista/direitos_estendidos"><label>9. DIREITOS ESTENDIDOS</label></input><select1 ref="/data/entrevista/barreiras_acessibilidade"><label>Enfrenta barreiras que dificultam a sua acessibilidade e mobilidade e que impedem de viver de forma independente? Referem-se a barreiras no geral, tanto no âmbito doméstico quanto da cidade.</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/entrevista/risco_desastre_violencia"><label>Vive em áreas de risco de desastre natural ou áreas violentas?</label><itemset nodeset="instance('sim_nao')/root/item"><value ref="name"/><label ref="label"/></itemset></select1></group></h:body></h:html>